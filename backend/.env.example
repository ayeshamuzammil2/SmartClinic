# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=smartclinic
DB_PASSWORD=smartclinic
DB_NAME=smartclinic

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# AI proxy (anthropic | openai). Leave AI_API_KEY empty to test graceful degradation.
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=claude-sonnet-5

# File uploads
UPLOAD_DIR=./uploads
